#!/usr/bin/env bash
# theme-forge setup script
# Installs theme-forge skills into the appropriate location for your platform.
#
# Usage:
#   ./setup              # Global install (solo developer)
#   ./setup --project    # Project-level install (team)
#   ./setup --help       # Show help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VERSION=$(cat "$SCRIPT_DIR/VERSION" | tr -d '[:space:]')

# Source platform detection
source "$SCRIPT_DIR/scripts/detect-platform.sh"

# ─── Argument parsing ───────────────────────────────────────────────

INSTALL_MODE="global"
INSTALL_DIR=""
VERBOSE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)  INSTALL_MODE="project"; shift ;;
    --dir)      INSTALL_DIR="$2"; shift 2 ;;
    --verbose)  VERBOSE=true; shift ;;
    --help|-h)
      echo "theme-forge v$VERSION — Setup"
      echo ""
      echo "Usage:"
      echo "  ./setup              Global install (skills available everywhere)"
      echo "  ./setup --project    Project install (skills in .claude/skills/)"
      echo "  ./setup --dir PATH   Install to a specific directory"
      echo ""
      echo "Platforms: Claude Code, Cowork, Codex, OpenClaw"
      exit 0
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# ─── Detect platform ────────────────────────────────────────────────

PLATFORM=$(detect_platform)
echo "🔍 Platform detected: $PLATFORM"

# ─── Determine install directory ─────────────────────────────────────

if [[ -n "$INSTALL_DIR" ]]; then
  TARGET_DIR="$INSTALL_DIR"
elif [[ "$INSTALL_MODE" == "project" ]]; then
  # Project-level: install into current project's .claude/skills/
  TARGET_DIR="$(pwd)/.claude/skills/theme-forge"
else
  # Global: install into platform's skills directory
  SKILLS_DIR=$(get_skills_dir)
  TARGET_DIR="$SKILLS_DIR/theme-forge"
fi

echo "📁 Install directory: $TARGET_DIR"

# ─── Skills to install ──────────────────────────────────────────────

SKILLS=(
  "theme-forge"
  "onboard"
  "scan"
  "map-section"
  "map-page"
  "reconcile"
  "pull-section"
  "pull-page"
  "pull-header"
  "pull-footer"
  "review"
  "status"
  "upgrade"
)

# ─── Install ─────────────────────────────────────────────────────────

if [[ "$SCRIPT_DIR" == "$TARGET_DIR" ]]; then
  echo "✅ Already installed at $TARGET_DIR"
else
  # Create target directory
  mkdir -p "$TARGET_DIR"

  # If this is a git clone, symlink each skill's SKILL.md
  if [[ -d "$SCRIPT_DIR/.git" ]]; then
    echo "📎 Creating symlinks from git clone..."
    for skill in "${SKILLS[@]}"; do
      skill_dir="$TARGET_DIR/$skill"
      mkdir -p "$skill_dir"

      # Symlink SKILL.md
      if [[ -f "$SCRIPT_DIR/$skill/SKILL.md" ]]; then
        ln -sf "$SCRIPT_DIR/$skill/SKILL.md" "$skill_dir/SKILL.md"
        $VERBOSE && echo "   ✓ $skill"
      fi

      # Symlink any references/ directory
      if [[ -d "$SCRIPT_DIR/$skill/references" ]]; then
        ln -sf "$SCRIPT_DIR/$skill/references" "$skill_dir/references"
      fi
    done
  else
    # Vendored copy — copy files directly
    echo "📋 Copying skill files..."
    for skill in "${SKILLS[@]}"; do
      if [[ -d "$SCRIPT_DIR/$skill" ]]; then
        mkdir -p "$TARGET_DIR/$skill"
        cp -r "$SCRIPT_DIR/$skill/"* "$TARGET_DIR/$skill/" 2>/dev/null || true
        $VERBOSE && echo "   ✓ $skill"
      fi
    done
  fi

  # Copy support files
  cp "$SCRIPT_DIR/VERSION" "$TARGET_DIR/VERSION"
  mkdir -p "$TARGET_DIR/scripts"
  cp "$SCRIPT_DIR/scripts/"*.sh "$TARGET_DIR/scripts/" 2>/dev/null || true
  chmod +x "$TARGET_DIR/scripts/"*.sh 2>/dev/null || true
  mkdir -p "$TARGET_DIR/config"
  cp "$SCRIPT_DIR/config/defaults.json" "$TARGET_DIR/config/defaults.json"
fi

# ─── Verify ──────────────────────────────────────────────────────────

echo ""
echo "═══════════════════════════════════════════"
echo "  theme-forge v$VERSION installed ✅"
echo "═══════════════════════════════════════════"
echo ""
echo "  Platform:  $PLATFORM"
echo "  Location:  $TARGET_DIR"
echo "  Mode:      $INSTALL_MODE"
echo "  Skills:    ${#SKILLS[@]} commands available"
echo ""
echo "  Quick start:"
echo "    /theme-forge onboard    — Configure your migration"
echo "    /theme-forge scan       — Inventory themes & plan"
echo "    /theme-forge pull-section <name> — Start pulling"
echo ""
echo "═══════════════════════════════════════════"

# ─── Check dependencies ─────────────────────────────────────────────

echo ""
echo "Checking optional dependencies..."

if command -v shopify &>/dev/null; then
  SHOPIFY_VERSION=$(shopify version 2>/dev/null || echo "unknown")
  echo "  ✅ Shopify CLI: $SHOPIFY_VERSION"
else
  echo "  ⚠️  Shopify CLI: not found (needed for theme dev preview)"
  echo "     Install: https://shopify.dev/docs/themes/tools/cli/install"
fi

if command -v git &>/dev/null; then
  echo "  ✅ Git: $(git --version | head -1)"
else
  echo "  ⚠️  Git: not found (needed for auto-updates)"
fi

echo ""
echo "Browse tool (gstack browse, Playwright MCP) and computer-use capabilities will be detected at runtime."
