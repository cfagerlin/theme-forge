#!/usr/bin/env bash
# theme-forge setup script
# Checks dependencies and optionally installs theme-forge to a different location.
#
# For most users, just cloning the repo is enough:
#   git clone https://github.com/cfagerlin/theme-forge.git ~/.claude/skills/theme-forge
#
# Run this script only if you need to:
#   - Check dependencies (Shopify CLI, Git, browse tools)
#   - Install to a non-standard location (--dir)
#
# Usage:
#   ./setup              # Check dependencies (no install needed if already cloned in place)
#   ./setup --dir PATH   # Copy/symlink skills to a different location
#   ./setup --help       # Show help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VERSION=$(cat "$SCRIPT_DIR/VERSION" | tr -d '[:space:]')

# Source platform detection
source "$SCRIPT_DIR/scripts/detect-platform.sh"

# ─── Argument parsing ───────────────────────────────────────────────

INSTALL_DIR=""
VERBOSE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)
      # Legacy flag — detect the project root (walk up to find .git or .claude)
      PROJECT_ROOT="$SCRIPT_DIR"
      while [[ "$PROJECT_ROOT" != "/" ]]; do
        if [[ -d "$PROJECT_ROOT/.git" ]] && [[ "$PROJECT_ROOT" != "$SCRIPT_DIR" ]]; then
          break
        fi
        PROJECT_ROOT="$(dirname "$PROJECT_ROOT")"
      done
      if [[ "$PROJECT_ROOT" == "/" ]]; then
        echo "⚠️  Could not find project root. If you cloned theme-forge directly into"
        echo "   .claude/skills/theme-forge, no setup is needed — it's already installed."
        echo ""
        echo "   Just restart Claude Code and run: /theme-forge onboard"
        exit 0
      fi
      INSTALL_DIR="$PROJECT_ROOT/.claude/skills/theme-forge"
      shift
      ;;
    --dir)      INSTALL_DIR="$2"; shift 2 ;;
    --verbose)  VERBOSE=true; shift ;;
    --help|-h)
      echo "theme-forge v$VERSION — Setup"
      echo ""
      echo "Usage:"
      echo "  ./setup              Check dependencies (if already cloned in place)"
      echo "  ./setup --dir PATH   Install to a specific directory"
      echo "  ./setup --project    Legacy: detect project root and install there"
      echo ""
      echo "Most users don't need to run setup at all. Just clone and go:"
      echo "  git clone https://github.com/cfagerlin/theme-forge.git ~/.claude/skills/theme-forge"
      echo ""
      echo "Platforms: Claude Code, Cowork, Codex, OpenClaw"
      exit 0
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# ─── Detect platform ────────────────────────────────────────────────

PLATFORM=$(detect_platform)
echo "Platform: $PLATFORM"

# ─── Sub-skills ──────────────────────────────────────────────────────

SKILLS=(
  "onboard"
  "scan"
  "map-section"
  "map-page"
  "reconcile"
  "capture"
  "pull-section"
  "pull-page"
  "pull-header"
  "pull-footer"
  "review"
  "status"
  "cutover"
  "upgrade"
)

# ─── Install (only if --dir or --project) ─────────────────────────────

if [[ -n "$INSTALL_DIR" ]]; then
  # Resolve to absolute path
  INSTALL_DIR="$(cd "$(dirname "$INSTALL_DIR")" 2>/dev/null && pwd)/$(basename "$INSTALL_DIR")"

  if [[ "$SCRIPT_DIR" == "$INSTALL_DIR" ]]; then
    echo "Already in the target directory — no install needed."
  else
    echo "Installing to: $INSTALL_DIR"
    mkdir -p "$INSTALL_DIR"

    # Copy/symlink the root SKILL.md (orchestrator)
    if [[ -d "$SCRIPT_DIR/.git" ]]; then
      echo "Creating symlinks from git clone..."
      ln -sf "$SCRIPT_DIR/SKILL.md" "$INSTALL_DIR/SKILL.md"

      for skill in "${SKILLS[@]}"; do
        skill_dir="$INSTALL_DIR/$skill"
        mkdir -p "$skill_dir"
        if [[ -f "$SCRIPT_DIR/$skill/SKILL.md" ]]; then
          ln -sf "$SCRIPT_DIR/$skill/SKILL.md" "$skill_dir/SKILL.md"
          $VERBOSE && echo "   $skill"
        fi
        if [[ -d "$SCRIPT_DIR/$skill/references" ]]; then
          ln -sf "$SCRIPT_DIR/$skill/references" "$skill_dir/references"
        fi
      done
    else
      echo "Copying skill files..."
      cp "$SCRIPT_DIR/SKILL.md" "$INSTALL_DIR/SKILL.md"
      for skill in "${SKILLS[@]}"; do
        if [[ -d "$SCRIPT_DIR/$skill" ]]; then
          mkdir -p "$INSTALL_DIR/$skill"
          cp -r "$SCRIPT_DIR/$skill/"* "$INSTALL_DIR/$skill/" 2>/dev/null || true
          $VERBOSE && echo "   $skill"
        fi
      done
    fi

    # Copy support files
    cp "$SCRIPT_DIR/VERSION" "$INSTALL_DIR/VERSION"
    mkdir -p "$INSTALL_DIR/scripts"
    cp "$SCRIPT_DIR/scripts/"*.sh "$INSTALL_DIR/scripts/" 2>/dev/null || true
    chmod +x "$INSTALL_DIR/scripts/"*.sh 2>/dev/null || true
    mkdir -p "$INSTALL_DIR/config"
    cp "$SCRIPT_DIR/config/defaults.json" "$INSTALL_DIR/config/defaults.json"
  fi

  LOCATION="$INSTALL_DIR"
else
  LOCATION="$SCRIPT_DIR"
fi

# ─── Verify structure ──────────────────────────────────────────────────

echo ""
SKILL_COUNT=1  # root SKILL.md
for skill in "${SKILLS[@]}"; do
  if [[ -f "$LOCATION/$skill/SKILL.md" ]]; then
    SKILL_COUNT=$((SKILL_COUNT + 1))
  fi
done

if [[ ! -f "$LOCATION/SKILL.md" ]]; then
  echo "WARNING: SKILL.md not found at $LOCATION/SKILL.md"
  echo "The /theme-forge command won't be discoverable."
  echo "Make sure you cloned the full repo."
  exit 1
fi

echo "theme-forge v$VERSION"
echo "  Location:  $LOCATION"
echo "  Skills:    $SKILL_COUNT commands"
echo ""

# ─── Check dependencies ─────────────────────────────────────────────

echo "Dependencies:"

if command -v shopify &>/dev/null; then
  SHOPIFY_VERSION=$(shopify version 2>/dev/null || echo "unknown")
  echo "  Shopify CLI $SHOPIFY_VERSION"
else
  echo "  Shopify CLI: not found (needed for theme dev preview)"
  echo "    Install: https://shopify.dev/docs/themes/tools/cli/install"
fi

if command -v git &>/dev/null; then
  echo "  Git $(git --version 2>/dev/null | sed 's/git version //')"
else
  echo "  Git: not found (needed for auto-updates)"
fi

# Check for browse tools
BROWSE_FOUND=false
if [[ -x "$HOME/.claude/skills/gstack/browse/dist/browse" ]]; then
  echo "  Browse: gstack browse"
  BROWSE_FOUND=true
elif [[ -x "$LOCATION/../gstack/browse/dist/browse" ]]; then
  echo "  Browse: gstack browse (project-level)"
  BROWSE_FOUND=true
fi

if ! $BROWSE_FOUND; then
  echo "  Browse: not found (visual comparison disabled)"
  echo "    Install: claude mcp add playwright -- npx @playwright/mcp --headless"
fi

echo ""
echo "Ready! Next steps:"
echo ""
echo "  1. cd into your target Shopify theme"
echo "  2. Run /theme-forge onboard to configure the migration"
echo "  3. Run /theme-forge pull-page index to start pulling the homepage"
echo ""
echo "For the full workflow: /theme-forge scan → /theme-forge pull-page <page>"
echo "Docs: https://github.com/cfagerlin/theme-forge"
